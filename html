.rpct{font-size:28px;font-weight:500;color:#085041}
.rtitle{font-size:18px;font-weight:500;margin-bottom:5px}
.rsub{font-size:12.5px;color:var(--color-text-secondary);margin-bottom:18px}
.rbtnrow{display:flex;gap:8px;justify-content:center;flex-wrap:wrap}
.rbtn{background:var(--color-background-secondary);color:var(--color-text-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-md);padding:8px 16px;font-size:12px;cursor:pointer;font-family:var(--font-sans)}
.rbtn:hover{border-color:var(--color-border-secondary)}
.rbtn.g{background:#E1F5EE;color:#085041;border-color:#9FE1CB}
